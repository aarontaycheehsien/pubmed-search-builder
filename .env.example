# NCBI E-utilities Configuration
#
# RECOMMENDED: Set your NCBI email for E-utilities compliance
# See: https://www.ncbi.nlm.nih.gov/books/NBK25497/#_chapter1_Setting_Up_Email_and_API_Key
NCBI_EMAIL=your.email@example.com

# OPTIONAL: NCBI tool name (default: codex-search-strategy-check)
# Used in NCBI API requests to identify your application
NCBI_TOOL=codex-search-strategy-check

# OPTIONAL: NCBI API key for higher rate limits (10 req/sec vs 3 req/sec)
# Request at: https://www.ncbi.nlm.nih.gov/account/register/
# IMPORTANT: Never commit your actual API key to version control
NCBI_API_KEY=your_api_key_here
